<div style="background: var(--bg-card); border: 1px solid var(--border-default); border-radius: 10px; padding: 14px; margin-bottom: 16px;">
  <h3 style="font-size: 14px; margin-bottom: 8px;{{if .Color}} color: {{.Color.Hex}};{{end}}">{{.Name}}</h3>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 8px;">
    {{- range .Items}}
    <div style="padding: 6px 10px; background: var(--bg-nested); border-radius: 6px; border: 1px solid var(--border-nested);">
      <strong style="font-size: 11px;">{{.Key}}</strong>
      <span style="color: var(--text-muted); font-size: 11px; display: block;">{{.Value}}</span>
    </div>
    {{- end}}
  </div>
</div>
