<div style="border: 1px solid {{if .Color}}{{.Color.Hex}}{{else}}var(--border-default){{end}}; border-radius: 10px; padding: 14px;">
  <div style="font-size: 13px; font-weight: 600; margin-bottom: 10px;{{if .Color}} color: {{.Color.Hex}};{{end}}">{{.Name}}</div>
  {{- range $i, $item := .Items}}
  <div style="padding: 6px 10px; margin-bottom: 4px; border-radius: 6px; font-size: 12px; background: var(--bg-nested); border: 1px solid var(--border-nested); display: flex; align-items: center; gap: 8px;">
    <span style="font-weight: 700; font-size: 11px; min-width: 18px;{{if $.Color}} color: {{$.Color.Hex}};{{end}}">{{add $.Start $i}}</span>
    {{$item}}
  </div>
  {{- end}}
</div>
